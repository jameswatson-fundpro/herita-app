# Required — primary webhook for application submissions
WEBHOOK_URL=https://your-crm.example.com/intake

# Optional — additional webhook (e.g. Slack / Zapier / Google Sheets via Apps Script)
# Leave blank to disable
SHEETS_WEBHOOK_URL=

# Optional — Resend API key for applicant confirmation emails
# Get one at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@yourdomain.com

# Required for /admin route — set to a long random string
ADMIN_PASSWORD=

# Optional — for verifying webhook delivery in admin
# Submissions are written here so /admin can read them; in production swap for a real DB.
# Set to "memory" to use the in-process store (resets on deploy).
SUBMISSIONS_STORE=memory

# Required for the address-autocomplete field on the apply form.
# Get a key in Google Cloud Console → APIs & Services → Credentials.
# In Google Cloud, enable "Maps JavaScript API" AND "Places API", then
# restrict the key to your domain(s) under Application restrictions.
# This is exposed to the browser (NEXT_PUBLIC_*) so the restriction is essential.
NEXT_PUBLIC_GOOGLE_PLACES_KEY=
